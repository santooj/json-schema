{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "age", "email", "phone", "gender", "pincode", "accountNumber"],
  "properties": {

    "name": {
      "type": "string",
      "pattern": "^[A-Za-z ]{3,50}$",
      "description": "Name must contain only letters and spaces (3-50 characters)"
    },

    "age": {
      "type": "integer",
      "minimum": 18,
      "maximum": 55
    },

    "email": {
      "type": "string",
      "format": "email"
    },

    "phone": {
      "type": "string",
      "pattern": "^[6-9][0-9]{9}$",
      "description": "Valid Indian mobile number"
    },

    "gender": {
      "type": "string",
      "enum": ["Male", "Female", "Other"]
    },

    "address": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200
    },

    "city": {
      "type": "string"
    },

    "state": {
      "type": "string"
    },

    "pincode": {
      "type": "string",
      "pattern": "^[1-9][0-9]{5}$",
      "description": "Valid Indian postal code"
    },

    "accountNumber": {
      "type": "string",
      "pattern": "^[0-9]{9,18}$",
      "description": "Bank account number between 9 and 18 digits"
    }

  }

}
