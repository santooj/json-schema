{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/userprofile.schema.json",
  "title": "UserProfile",
  "type": "object",
  "required": ["profileId", "customer", "questions", "historicalDebts", "depositSrcType"],

  "$defs": {
    "Money": {
      "type": "object",
      "required": ["currency", "amount"],
      "properties": {
        "currency": {
          "type": "string",
          "enum": ["INR", "USD", "EUR", "GBP"],
          "description": "ISO 4217 currency code"
        },
        "amount": {
          "type": "number",
          "minimum": 0,
          "description": "Monetary value in the specified currency"
        }
      }
    }
  },

  "properties": {
    "profileId":  { "type": "string" },
    "createdAt":  { "type": "string", "format": "date-time" },

    "customer": {
      "type": "object",
      "required": ["customerId", "name", "email"],
      "properties": {
        "customerId": { "type": "string" },
        "name":       { "type": "string" },
        "email":      { "type": "string", "format": "email" },
        "phone":      { "type": "string" }
      }
    },

    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["questionId", "text"],
        "properties": {
          "questionId": { "type": "string" },
          "text":       { "type": "string" },
          "category":   { "type": "string" },
          "answer":     { "type": "string" },
          "answeredAt": { "type": "string", "format": "date-time" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "historicalDebts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["debtType", "monthlyPayment"],
        "properties": {
          "debtId": { "type": "string" },
          "debtType": {
            "type": "string",
            "enum": ["home_loan", "car_loan", "personal_loan", "credit_card", "student_loan", "other"]
          },
          "monthlyPayment": {
            "$ref": "#/$defs/Money",
            "description": "Monthly EMI or payment amount"
          },
          "details": {
            "type": "string",
            "description": "Allows $, /, - and € but not # or %",
            "pattern": "^[^#%]*$"
          },
          "startDate":      { "type": "string", "format": "date" },
          "outstandingAmt": {
            "$ref": "#/$defs/Money",
            "description": "Remaining outstanding balance"
          }
        }
      }
    },

    "depositSrcType": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["depositAmt", "srcOfDeposit"],
        "properties": {
          "depositId": { "type": "string" },
          "depositAmt": {
            "$ref": "#/$defs/Money",
            "description": "Amount deposited"
          },
          "srcOfDeposit": {
            "type": "string",
            "enum": ["salary", "business", "rental", "investment", "gift", "inheritance", "other"]
          },
          "depositDetails": { "type": "string" },
          "taxDesc":        { "type": "string" },
          "depositDate":    { "type": "string", "format": "date" }
        }
      }
    }

  }
}
